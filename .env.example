# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: guild/server ID for instant slash command registration (faster for dev)
# Leave empty to register globally (can take up to 1 hour to propagate)
DISCORD_GUILD_ID=

# Anthropic API key (from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Role name that is allowed to upload/remove books (case-insensitive)
ADMIN_ROLE_NAME=DM

# Path to the SQLite database file
DB_PATH=./rules.db

# Directory to scan on startup for PDF rulebooks
PDF_DIR=./pdfs
